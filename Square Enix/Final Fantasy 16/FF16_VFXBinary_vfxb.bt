void GenerateItemProperty()
{
    PropertyType Type <bgcolor=cGreen>;
    short Size <bgcolor=cBlue>;
    int Count <fgcolor=cGreen>;
    VarOffset field_0x3(30, 2);
    short field_0x4 : 6;
    short field_0x4a : 10;
    short field_0x5;
    Offset24 field_0x6, field_0x7;
    OffsetT field_0x8, field_0x9;
    
    FSeek(parentof(this).address_0x0 + field_0x3.offset);
    struct
    {
        OffsetT Offset;
        float field_0x4;
        Offset24 field_0x8;
        Offset24 field_0xC;
    } ItemInfo[Count]<bgcolor=0x92006D>;
    
    for (local int j = 0; j < Count; j++)
    {
        FSeek(Header_.ItemBlobInfo.items_address + ItemInfo[j].Offset);
        Item item<bgcolor=0x92006D>;
    }
     
    if (field_0x8 > -1)
    {
        FSeek(Header_.ItemBlobInfo.properties_address + field_0x8);
        OffsetT field_0xA<bgcolor=0x92006D>;
        FSeek(Header_.ItemBlobInfo.properties_address + field_0xA);
        float field_0xB<bgcolor=0x92006D>;
    }
    
    if (field_0x9 > -1)
    {
        FSeek(Header_.ItemBlobInfo.properties_address + field_0x9);
        OffsetT field_0xC<bgcolor=0x92006D>;
        
        FSeek(Header_.ItemBlobInfo.properties_address + field_0xC);
        float field_0xD<bgcolor=0x92006D>;
    }
    
    
    FSeek(startof(this) + Size);
}

