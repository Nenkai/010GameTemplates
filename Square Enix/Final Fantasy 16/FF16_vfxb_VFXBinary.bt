void GenerateItemType_7()
{
    Offset30 MatrixOffset;

    FSeek(GetOffset(MatrixOffset));
    float Matrix[4*4] <bgcolor=cWhite>;
}

void GenerateItemGroupProperty()
{
    ubyte Count : 4;
    byte Flag : 1;
    byte Flag2 : 1;
    uint pad : 26;
    Offset30 ItemInfosOffset;
    ushort IndexInto0x3C_0x40 : 6;
    ushort Field_0x0C_Bits2 : 10;
    ushort field_0x0E;
    Offset30 field_0x10;
    Offset30 field_0x14;
    Offset30 VMOffset0x18;
    Offset30 VMOffset0x1C;
    
    local int actualItemInfosOffset = GetOffset(ItemInfosOffset);
    if (actualItemInfosOffset)
    {
        FSeek(actualItemInfosOffset);
        struct
        {
            OffsetT Offset;
            float Float_0x04;
            float Float_0x08;
            float Float_0x0C;
        } ItemInfo[Count] <optimize=false, bgcolor=0x92006D>;
    }
    
    // This bit evaluates a single float value.
    local int o18 = GetOffset(VMOffset0x18);
    if (o18)
    {
        FSeek(o18);
        VFX_VM VFX_VM_0x18;
    }
    
    local int o1C = GetOffset(VMOffset0x1C);
    if (o1C)
    {
        FSeek(o1C);
        VFX_VM VFX_VM_0x1C;
    }
    
    for (local int j = 0; j < Count; j++)
    {
        FSeek(Toc2.ItemBlobInfo.items_address + ItemInfo[j].Offset);
        ItemGroup ItemGroup_ <bgcolor=0x92006D>;
    }
}

void GenerateItemType_30()
{
    Offset30 MatrixOffset;
    float Float_0x0C;
    float Float_0x10;
    
    FSeek(GetOffset(MatrixOffset));
    float Matrix[4*4] <bgcolor=cWhite>;
}


void GenerateItemType_138()
{
    Offset30 VMInstructionsOffset;
    Offset30 VMDataOffset;
    int RetVMValue;
    byte VMInstructionsSize;
    byte VMDataSize;
    byte TimeSourceType;
}

void GenerateItemType_139()
{
    Offset30 ValueOffset;
    Offset30 RetVMValueLocation;
    byte Unk1;
    byte Unk2;
    
    FSeek(GetOffset(ValueOffset));
    float Value;
}

void GenerateItemType_143()
{
    Offset30 CurveOffset;
    Offset30 RetValueOffset;
    ubyte TimeSourceType;
    ubyte Unk;
}

typedef struct TItem
{
    PropertyType Type <bgcolor=cGreen>;
    ushort Size <format=hex, bgcolor=cBlue>;

    switch (Type)
    {
        case kPropertyType_1: /* nothing */ break;
        case kPropertyType_3: /* nothing */ break;
        case kPropertyType_7: GenerateItemType_7(); break;
        case kPropertyType_30: GenerateItemType_30(); break;
        case kPropertyType_37: /* nothing */ break;
        case kPropertyType_39: /* nothing */; break;
        case kPropertyType_ItemGroup: GenerateItemGroupProperty(); break;
        case kPropertyType_138: GenerateItemType_138(); break;
        case kPropertyType_139: GenerateItemType_139(); break;
        case kPropertyType_143: GenerateItemType_143(); break;
        /*
        case kPropertyType_49: GenerateProperty_49(); break;
        case kPropertyType_140: GenerateProperty_140(); break;
        case kPropertyType_142: GenerateProperty_142(); break;
        case kPropertyType_145: GenerateProperty_145(); break;
        case kPropertyType_165: GenerateProperty_165(); break;
        */
        default: 
            Printf("Unknown Item Type %d\n", Type);
            byte Bytes[Size - 0x04]; 
            break;  
    }
    
    FSeek(startof(this) + Size);
} Item <read=EnumToString(this.Type)>;

typedef struct TItemGroup
{
    // 41 BA ? ? ? ? 41 83 78
    
    OffsetT LocalPropertyDataOffset; // Defines Type 1
    OffsetT LocalPropertyDataSize;   // Defines Type 1
    int ItemsSize : 24 <format=hex>;
    int ItemsOffset : 8 <comment="Relative to 0x7C, aka end of this">;

    float Float_0xC;
    float Float_0x10;
    float Float_0x14;
    
    int MaybeUnused_0x18;
    Offset30 field_0x1C;
    
    // These 3 go together in purpose
    Offset30 FloatArrayOffset;
    Offset30 MaybeUVArrayOffset;
    int FloatArrayLength;
    
    int field_0x2C;
    int field_0x30;
    int field_0x34;
    
    // These 4 go together in purpose
    uint Count_0x38_For0x3C_0x40 <fgcolor=cGreen>;
    Offset30 Offset_0x3C; // Stride 0x14
    Offset30 Offset_0x40; // Stride 0x60
    Offset30 Offset_0x44;
    
    Offset30 Offset_0x48;
    
    Offset30 Offset_0x4C;
    Offset30 MatrixOffset;
    
    int field_0x54;
    
    VarOffset Offset_0x58(31, 1);
    
    Offset30 Offset_0x5C;
    int field_0x60;
    
    Offset30 Offset_0x64;
    
    Offset30 Offset_0x68; // Stride 0x0C
    uint Count_0x6C_For0x68;
    
    uint HashSeed <format=hex>;
    int field_0x74;
    int field_0x78;
    
    local int actualFloatArrayOffset = GetOffset(FloatArrayOffset);
    if (actualFloatArrayOffset)
    {
        FSeek(actualFloatArrayOffset);
        struct
        {
            float Value;
        } FloatArray[FloatArrayLength] <bgcolor=cBlue>;
    }
    
    local int maybeUvArrayOffset = GetOffset(MaybeUVArrayOffset); 
    if (maybeUvArrayOffset)
    {
        struct
        {
            int Flags;
            float U;
            float V;
        } MaybeUVArray[FloatArrayLength]  <bgcolor=cDkBlue>;
    }
    
    local int actualOffset0x3C = GetOffset(Offset_0x3C); 
    if (actualOffset0x3C)
    {
        struct
        {
            int Field_0x00;
            int Field_0x04;
            int Field_0x08;
            float Field_0x0C;
            int RuntimeHash <format=hex>;
        } Offset0x3C_Data[Count_0x38_For0x3C_0x40]  <bgcolor=cRed>;
    }
    
    local int actualOffset0x40 = GetOffset(Offset_0x40); 
    if (actualOffset0x40)
    {
        struct
        {
            int Field_0x00;
            int Field_0x04;
            int Field_0x08;
            int Field_0x0C;
            int Field_0x10;
            int Field_0x14;
            int Field_0x18;
            int Field_0x1C;
            int Field_0x20;
            int Field_0x24;
            int Field_0x28;
            int Field_0x2C;
            int Field_0x30;
            int Field_0x34;
            int Field_0x38;
            int Field_0x3C;
            int Field_0x40;
            int Field_0x44;
            int Field_0x48;
            int Field_0x4C;
            int Field_0x50;
            int Field_0x54;
            int Field_0x58;
            int Field_0x5C;
        } Offset0x40_Data[FloatArrayLength]  <bgcolor=cDkRed>;
    }
    
    local int maybeOffset_0x64 = GetOffset(Offset_0x64);
    if (maybeOffset_0x64)
    {
        FSeek(GetOffset(Offset_0x64));
        float Matrix_0x64[3*3];
    }
    
    local int dataEnd;
    if (ItemsSize != 0)
        dataEnd = (startof(this) + 0x7C) + ItemsSize;
    else
        dataEnd = (startof(this) + 0x7C) + ItemsOffset;
    
    // Game actually loops that way.
    FSeek(startof(this) + 0x7C + ItemsOffset);
    struct
    {
        local int i = 0;
        while (FTell() < dataEnd)
        {
            Item Item_ <bgcolor=cNone>;
            i++;
        }
    } Items <read=Str("%d Items", i)>;
    
    
} ItemGroup;


//////////////////////////////////////////////////////////////////
// HEADER START
//////////////////////////////////////////////////////////////////

struct
{
    char Magic[4] <fgcolor=cYellow, comment="'VFXB', unchecked.">;
    ubyte Magic2 <format=hex, comment="FFXVI: PC: 0xAE. Must be 0xAE on PC. > 0x0E on PS5. CHECKED.">;
    byte field_0x5 <comment="PC: 1, Must be 0x04 on PS5.">;
    byte field_0x6 <comment="Unused.">;
    // Padding
} Header <bgcolor=cPurple, size=0x08>;

struct
{
    uint GlobalPropertyDataSize <format=hex>; // Defines Type 0's Size. Offset is ItemBlobInfo->ItemBlobStartOffset + PropertiesOffset
    uint ItemBlobSize <format=hex>;
    uint TotalDataSize <format=hex, comment="item + property data size">;
    uint ConstantDataSize <format=hex>;
    int VertexSetCount <fgcolor=cGreen>;
    ubyte TextureCount <fgcolor=cGreen>;
    ubyte ConstantCount <fgcolor=cGreen>;
    ubyte ConstantLastIndex;
    ubyte TextureDescriptorCount <fgcolor=cGreen>;
    ubyte ResourceCount <fgcolor=cGreen>;
    ubyte Struct0x1EC_Data2_Count <fgcolor=cGreen>;
    ubyte Count_0x22; // 41 0F B6 87 ? ? ? ? 44 3B C0
    ubyte field_0x23; // 41 0F B6 84 24 ? ? ? ? 3B D8
    byte field_0x24;
    byte field_0x25;
    ushort field_0x26; // 41 0F B7 87 ? ? ? ? 41 0F B7 8F - v14 = (unsigned __int16)(VFXInstance->VFXBToc1.field_0x26 & VFXInstance->VFXBToc1.field_198)
    struct
    {
        uint SlotCount : 4;
        uint SlotIdx0  : 4;   // bits 0-3
        uint SlotIdx1  : 4;   // bits 4-7
        uint SlotIdx2  : 4;   // bits 8-11
        uint SlotIdx3  : 4;   // bits 12-15
        uint SlotIdx4  : 4;   // bits 16-19
        uint SlotIdx5  : 4;   // bits 20-23
        uint SlotIdx6  : 4;   // bits 24-27
        uint SlotIdx7  : 4;   // bits 28-31
        uint SlotIdx8  : 4;   // bits 32-35
        uint SlotIdx9  : 4;   // bits 36-39
        uint SlotIdx10  : 4;   // bits 40-43
        uint SlotIdx11  : 4;   // bits 44-47
        uint SlotIdx12  : 4;   // bits 48-51
        uint SlotIdx13  : 4;   // bits 52-55
        uint SlotIdx14  : 4;   // bits 56-59
    } TypeToItemIndices;
    
    struct TItemEntry
    {
        OffsetT ItemOffset;
        uint Flags <format=hex>;
        short Offset2;
        byte CountMaybe;
        ubyte Unk;
        int field_0x0C;
    } RootItemInfo[15];
    
    struct
    {
        int Unk1 : 6;
        int Unk2 : 6;
        int rest: 20;
    } Field_0x120; // C4 42 43 F7 84 24
    int field_0x124;
    int field_0x128;
    int field_0x12C; // 41 8B 87 ? ? ? ? 41 89 46 ? 8B 45
    int field_0x130;
    int field_0x134;
    short field_0x138_ForProjectInfo; // 0F B7 81 ? ? ? ? 33 D2 49 8B F0
    short field_0x13A;
    ubyte Count_0x13C;
    ubyte Count_0x13D_For_0x1EC <edit=check, comment="Bool">;
    ubyte field_0x13E; // 0F B6 86 ? ? ? ? 48 8D 14 40 - 12LL * vfxInst->VFXBToc1.field_13e
    byte field_0x13F;
    float field_0x140;
    float field_0x144; //  C5 FA 10 80 ? ? ? ? EB ? C5 F0 57 05, 41 8B 80 ? ? ? ? 89 83 ? ? ? ? 0F B7 84 24
    int field_0x148;
    float field_0x14C;
    short field_0x150; // 44 0F B7 8E ? ? ? ? 83 E0
    short field_0x152;
    
    // 0x20 - 8B 81 ? ? ? ? C1 E8 ? 24 ? 48 8B 97
    int Flags_0x154 <format=hex, comment="If 0x8000, create a constant buffer for offset at 0x19C?">;
    short field_0x158; // 66 39 90 ? ? ? ? 75
    short field_0x15A; // 66 39 90 ? ? ? ? 75
    int field_0x15C;
    float field_0x160;
    float field_0x164;
    float field_0x168;
    float field_0x16C;
    float field_0x170;
    float field_0x174;
    int field_0x178;
    float field_0x17C;
    int field_0x180;
    float field_0x184;
    byte field_0x188;
    byte field_0x189; // 0F B6 8E ? ? ? ? 48 8D 55
    short field_0x18A;
    int field_0x18C;
    int field_0x190;
    int field_0x194;
    uint BitMask_0x198 <format=hex>; // 41 0F B7 8F ? ? ? ? 23 C8
    Offset30 ConstantBufferFlags;
    int field_0x1A0;
    int field_0x1A4;
    int field_0x1A8;
    byte field_0x1AC;
    byte field_0x1AD;
    byte field_0x1AE;
    byte Flags_0x1AF; // 0F B6 8E ? ? ? ? 49 8D 9F
    int field_0x1B0;
    int field_0x1B4;
} Toc;

struct
{
    struct
    {
        AddressT Offset;
        uint Size;
    } ShaderBlobInfo <read=Str("%Xh, %d bytes", this.Offset, this.Size)>;
    
    struct{
        AddressT Offset;
        int field_0x04;
        int field_0x08;
    } ResourceInfo <read=Str("%Xh", this.Offset)>;
    
    struct{
        AddressT Offset;
        int field_0x04;
    } TextureDescriptorInfo <read=Str("%Xh", this.Offset)>;
    
    struct
    {
        // The main one. This + ItemBlobSize
        AddressT ItemBlobStartOffset;
        
        OffsetT PropertiesOffset; // USED
        OffsetT ItemsOffset; // USED
        OffsetT ConstantsOffset; // USED
        OffsetT Offset_0x1E4;
        OffsetT ConstantDataOffset; // USED
        OffsetT Offset_0x1EC;
        OffsetT field_0x1F0;
        OffsetT VertexSetOffset; // USED
        OffsetT TextureIndicesOffset; // USED
        OffsetT ProjectInfoOffset; // USED
        OffsetT Offset_0x200;
        OffsetT field_0x204; // USED
        OffsetT Offset_0x208;
        OffsetT TextureGroupsOffset; // USED
        
        local AddressT GlobalPropertyDataOffset = ItemBlobStartOffset + PropertiesOffset;
        local AddressT items_address = ItemBlobStartOffset + ItemsOffset;
        local AddressT ConstantsAddress = ItemBlobStartOffset + ConstantsOffset;
        local AddressT ConstantDataAddress = ItemBlobStartOffset + ConstantDataOffset;
        local AddressT VertexSetAddress = ItemBlobStartOffset + VertexSetOffset;
        local AddressT texture_indices_address = ItemBlobStartOffset + TextureIndicesOffset;
        local AddressT project_info_address = ItemBlobStartOffset + ProjectInfoOffset;
        local AddressT texture_groups_address = ItemBlobStartOffset + TextureGroupsOffset;
    } ItemBlobInfo <open=true>;
} Toc2;

FSeek(Toc2.ShaderBlobInfo.Offset);
ubyte ShaderBlob[Toc2.ShaderBlobInfo.Size]<bgcolor=cBlack, fgcolor=cGray>;

FSeek(Toc2.ResourceInfo.Offset);
StringT Resources[Toc.ResourceCount]<fgcolor=cYellow, optimize=false>;

struct
{
    for (local int i = 0; i < Toc.TextureDescriptorCount; i++)
    {
        FSeek(Toc2.TextureDescriptorInfo.Offset + i * 0x0C);
        struct
        {
            ubyte TextureIndex;
            enum <byte>
            {
                R32_FLOAT = 0, // 0x46150 - R32_FLOAT
                R32G32_FLOAT = 1, // 0xB6260 - R32G32_FLOAT
                R32G32B32A32_FLOAT = 2, // 0xE6470 - R32G32B32A32_FLOAT
                R16_FLOAT = 3, // 0x26140 - R16_FLOAT
                R16G16B16A16_FLOAT = 4, // 0xC6460 - R16G16B16A16_FLOAT 
                R8_UNORM = 5, // 0x11130 - R8_UNORM
                R8G8B8A8_UNORM = 6, // 0xA1450 - R8G8B8A8_UNORM
            } FormatType : 7;
            byte UnkBit : 1;
            ushort Width;
            ushort DimensionType;
            ushort Height;
            OffsetT DataOffset;
            
            FSeek(startof(this) + DataOffset);
            switch (FormatType)
            {
                case R32_FLOAT:
                    float Data[Width * Height]; break;
                case R32G32_FLOAT:
                    float Data[Width * Height * 2]; break;
                case R32G32B32A32_FLOAT:
                    float Data[Width * Height * 4]; break;
                case R16_FLOAT:
                    hfloat Data[Width * Height]; break;
                case R16G16B16A16_FLOAT:
                    hfloat Data[Width * Height * 4]; break;
                case R8_UNORM:
                    byte Data[Width * Height]; break;
                case R8G8B8A8_UNORM:
                    byte Data[Width * Height * 4]; break;
            }
        } TextureDescriptor;
    }
} TextureDescriptors <bgcolor=cLtBlue, read=Str("Count: %d", Toc.TextureDescriptorCount)>;

FSeek(Toc2.ItemBlobInfo.VertexSetAddress);
struct
{
    short name_offsets[Toc.VertexSetCount] <fgcolor=cRed>;
    
    for(local int j = 0; j < Toc.VertexSetCount; j++)
    {
        FSeek(startof(this) + sizeof(name_offsets) + name_offsets[j]);
        StringT Set<fgcolor=cYellow>;
    }
} VertexSets <read=Str("count: %d", Toc.VertexSetCount), bgcolor=0xC9A91C>;

FSeek(Toc2.ItemBlobInfo.project_info_address);
struct
{
    int field_0x00;
    int field_0x04;
    int ItemCount <fgcolor=cGreen>;
    Padding padding(32);
    int field_0x2C;
    int field_0x30;
    Padding padding_1(20);
} project_info<bgcolor=cDkGreen>;

FSeek(Toc2.ItemBlobInfo.texture_indices_address);
int64 TextureResourceIndices[Toc.TextureCount]<bgcolor=cRed>;

if (Toc.ConstantCount)
{
    struct
    {
        for (local int i = 0; i < Toc.ConstantCount; i++)
        {
            FSeek(Toc2.ItemBlobInfo.ConstantsAddress + (i * 0x10));
            ConstantEntry Constant;
        }
        
        FSeek(Toc2.ItemBlobInfo.ConstantsAddress + (Toc.ConstantCount * 0x10));
        
        // This is indexed first. Group type is hardcoded on the game side
        // So each type must have a different purpose of some kind?
        
        // essentially: GetConstantGroup(int index)
        // return &Constants[ConstStartIndexPerGroupType[index + 1] - ConstStartIndexPerGroupType[index]];
        // This matches the number of root items in the main toc.
        byte ConstStartIndexPerGroupType[16];
    } ConstantGroups<read=Str("Count: %d", Toc.ConstantCount), bgcolor=cBlue>;
}

for (local int i = 0; i < 15; i++)
{
    if (Toc.RootItemInfo[i].ItemOffset == 1)
        continue;
    
    FSeek(Toc2.ItemBlobInfo.items_address + Toc.RootItemInfo[i].ItemOffset);
    ItemGroup ItemGroup_ <bgcolor=0xFF00BF>;
}
