//////////////////////////////////////////////////////////////////
// GENERAL PURPOSE STRUCTURES
//////////////////////////////////////////////////////////////////
typedef int OffsetT <fgcolor=cRed, format=hex>;
typedef int AddressT <fgcolor=cPurple, format=hex>;

typedef struct TPadding(uint64 count)
{
    local uint64 PaddingCount <hidden=true> = count;
    byte Data[PaddingCount];
} Padding<bgcolor=cNone, read=Str("%u bytes", this.PaddingCount)>;

typedef struct TOffset30
{
    int Offset : 30;
    enum <int>
    {
        OffsetType_PropertyDataGlobal = 0,
        OffsetType_LocalPropertyData = 1,
        OffsetType_Unk2 = 2,
        OffsetType_None = 3,
    } Type : 2;
} Offset30<fgcolor=0x008CFF, read=Str("%Xh (%s)", this.Offset, EnumToString(this.Type))>;

int IsValidOffset(Offset30& offs)
{
    return offs.Offset != 0x3FFFFFFF && offs.Type != OffsetType_None;
}

uint GetOffset(Offset30& offs)
{
    if (!IsValidOffset(offs))
        return 0;
        
    switch (offs.Type)
    {
        case OffsetType_PropertyDataGlobal:
            return Toc2.ItemBlobInfo.GlobalPropertyDataOffset + offs.Offset;
        case OffsetType_LocalPropertyData:
            return Toc2.ItemBlobInfo.GlobalPropertyDataOffset + LocalPropertyDataOffset + offs.Offset;
    }   
}

typedef struct TVarOffset(ubyte offsetSize, ubyte flagSize)
{
    local ubyte offset_size = offsetSize;
    local ubyte flag_size = flagSize;
    
    int offset : offset_size;
    int flags : flag_size;
} VarOffset<fgcolor=0x008CFF, read=Str("%Xh, %s", this.offset, IntToBinaryStr(this.flags))>;

typedef struct TStringT{
    string data;
} StringT<read=this.data>;

typedef struct TVector3{
    float x, y, z;
} Vector3<read=Str("%.3f, %.3f, %.3f", this.x, this.y, this.z)>;

typedef struct TVector4{
    float x, y, z, w;
} Vector4<read=Str("%.3f, %.3f, %.3f, %.3f", this.x, this.y, this.z, this.w)>;

//////////////////////////////////////////////////////////////////
// TEMPLATE SPECIFIC TYPEDEFS
//////////////////////////////////////////////////////////////////

enum<byte> ConstantDataType
{
    kMatrix4x4 = 0,
    kVector4 = 1,
    kUnkType2 = 2,
    kFloat32 = 3,
};

typedef struct TConstantEntry
{
    ConstantDataType Type;
    ubyte NameLength <format=hex>;
    ubyte NameOffset <format=hex, fgcolor=cRed>;
    byte Field_0x03;
    int ConstantId;
    uint EidId;
    int ConstantDataOffset <format=hex, comment="Relative to the start offset (ConstantDataAddress)">;
    
    FSeek(Toc2.ItemBlobInfo.ConstantsAddress + (Toc.ConstantCount * 0x10) + 0x10 + NameOffset);
    string Name <fgcolor=cYellow>;
    
    FSeek(Toc2.ItemBlobInfo.ConstantDataAddress + ConstantDataOffset);
    struct
    {
        switch (Type)
        {
            case kMatrix4x4: float Matrix[4*4]; break; // Maybe more?
            case kFloat32: float Value; break;
            case kVector4: Vector4 Value; break;
            default: int temp; break;
        }
    } Data;
} ConstantEntry<read=Str("[Id %d, Eid %d] %s %s", ConstantId, EidId, EnumToString(this.Type), this.Name == "" ? "<No Name>" : this.Name)>;

struct ItemGroup;

typedef struct TTextureGroup
{
    byte indices[8];
    local int count = 0;
    local int i <hidden=true>;
    local int64 texResourceIndex <hidden=true> = -1;
    for(i = 0; i < 8; i++)
    {
        if(indices[i] == -1)
            continue;
            
        count += 1;
        texResourceIndex = TextureResourceIndices[indices[i]];
        local StringT resource;
        if(texResourceIndex > 255)
            continue;
        resource.data = Resources[texResourceIndex].data;
        
    }
} TextureGroup;

enum KeyType
{
    k0 = 0x0,
    k1 = 0x1,
    k2 = 0x2,
    kVector3 = 0x3
};

typedef struct TKey2
{
    Vector4 v1;
    Vector3 v2;
} Key2;

typedef struct TKey
{
    KeyType type<bgcolor=0xFF0063>;
    float time;
    switch(type)
    {
        case k0: float value; break;
        case k1: float value; break;
        case k2: Key2 value; break;
        case kVector3: Vector3 value; break;
        default: break;
    }
} Key <read=Str("%s", EnumToString(this.type))>;

typedef struct TKeyList
{
    int count<fgcolor=cGreen>;
    for (local int j = 0; j < count; j++)
        Key key;
        
} KeyList<read=Str("keys: %d", this.count)>;

typedef struct
{
    // Func handler: 48 8B C4 48 89 58 ? 55 56 57 41 54 41 55 41 56 41 57 48 8D 68 ? 48 81 EC ? ? ? ? C5 F8 29 70 ? C5 F8 29 78 ? C5 78 29 40 ? C5 78 29 48 ? C5 78 29 90 ? ? ? ? C5 78 29 98 ? ? ? ? 48 8B 05 ? ? ? ? 48 33 C4 48 89 45 ? 48 8B 41
    
    Offset30 DataSectionOffset;
    ubyte InstructionsLength;
    ubyte DataLength;
    FSkip(2);
    
    local long instStart = FTell();
    
    // Instructions start.
    while (FTell() < (instStart + InstructionsLength))
    {
        enum <byte>
        {
            // The later ones will need verification, patterns were mostly recognized by AI.
            
            PushConst = 0,
            
            // same delta value passed to curve interpolation function
            
            PushTime = 1,
            
            // Returns an interpolated curve value from the specified curve.
            // Arguments: inst = int offset into data, data value is offset into curve.
            ReturnCurveValue = 2,
            
            // Pushes a float from a pointer from data section.
            // Arguments: inst = int offset into data, data value is offset into float value.
            PushFloat = 3,
            
            // Pushes uint (casted to float) from data section.
            // Arguments: inst = int offset into data, data value is offset into uint value.
            PushUInt = 4,
            
            // Pushes random float value [0, 1] from PRNG (xorshift seeded).
            PushRand = 5,
            
            // Pushes random float value rom PRNG (xorshift seeded) % value.
            // Arguments: inst = int offset into data, data value is uint as the value to mod with.
            // hash % value
            PushRandMod = 6,
            
            // Returns perlin noise (?), value popped from stack. PerlinNoise(time * frequency)
            PerlinNoise = 7,
            
            // Pops 3 values
            // lerp(data[A], data[B], (sin(X)+1)*0.5)
            SinLerp2 = 8,
            
            // Pops 3 values
            // sinblend(data[A], data[B], data[C])
            SinLerp3 = 9,
            
            // Pops 2 values
            // a+b
            Add = 10,
            
            // Pops 2 values
            // a*b
            Multiply = 11,
            
            // Pops 2 values
            // a/b
            Divide = 12,
            
            // Pops 2 values
            // a/safe(b)
            DivideSafe = 13,
            
            // Pops 3 values
            // a*b+c
            FMA = 14,
            
            // Pops 3 values
            // (b-a)*t + a
            Lerp = 15,
            
            // max(0, x)
            Max0 = 16,
            
            // Pops 2, pushes min
            // min(a, b)
            Min = 17,
            
            // Pops 2, pushes max(a, b)
            Max = 18,
            
            // Pops 1, writes to tagged pointer from data[inst[0]]; side-effecting
            Store = 19,
            
            // Pops 2
            ModSafe = 20,
            
            // Returns the float at the start of the data pool
            ReturnFloatConstant = 21,
            
            // Returns the uint (casted to float) at the start of the data pool
            ReturnUIntConstant = 22,
            
            // lerp(Curve(data[2], time), Curve(data[1], time), ptr(data[0]))
            CurveCrossfade = 23,
            
            // abs(Curve(ptr(data[0]), time))
            CurveAbs = 24,
            
            // Curve(ptr(data[0]), time)
            Curve = 25,
            
            // ptr(data[1]) + data[0]
            AddConst = 26,
            
            // Curve(ptr(data[0]), time) + ptr(data[1])
            CurveAddPtr = 27,
            
            // lerp(data[0], data[1], rng())
            RandLerp = 28,
            
            // lerp(Curve(data[2], time), Curve(data[1], time), ptr(data[0])) + ptr(data[3])
            CurveCrossfadeAdd = 29,
            
            // X = 2pi * (ptr(data[1]) / ptr(data[2])) + ptr(data[3])
            // result = lerp(ptr(data[5]), ptr(data[4]), (sin(X)+1)*0.5) + ptr(data[0])
            SinLerp2Add = 30,
            
            // abs(lerp(Curve(data[2], time), Curve(data[1], time), ptr(data[0])))
            CurveCrossfadeAbs = 31,
            
            // lerp(Curve(data[0], time), Curve(data[1], time), rng())
            RandCrossfade = 32,
            
            // abs(Curve(ptr(data[0]), time) + ptr(data[1]))
            CurveAddPtrAbs = 33,
            
            // max(0, Curve(ptr(data[0]), time))
            CurveRelu = 34,
            
            // data[0] * ptr(data[1])
            ConstMulPtr = 35,
            
            // lerp(data[2], Curve(ptr(data[1]), time), ptr(data[0]))
            CurveConstCrossfade = 36,
            
            // X = 2pi * (ptr(data[1]) / ptr(data[2])) + ptr(data[3])
            // result = Curve(ptr(data[0]), time) + lerp(ptr(data[5]), ptr(data[4]), (sin(X)+1)*0.5)
            SinLerp2PtrAddCurve = 37,
            
            // lerp(ptr(data[4]), ptr(data[0]), (sin(X)+1)*0.5) * ptr(data[0])
            SinLerp2PtrSelfMul = 38,
            
            // X = 2π * (ptr(data[1]) / ptr(data[2])) + ptr(data[3])
            // result = Curve(ptr(data[0]), time) * lerp(ptr(data[5]), ptr(data[4]), (sin(X)+1)*0.5)
            SinLerp2PtrMulCurve = 39,
            
            // abs(Curve(ptr(data[0]), time) + ptr(data[2]) * data[1])
            CurveAddPtrMulConstAbs = 40,
            
            // ptr(data[2]) * data[1] + data[0]
            PtrMulConstAddConst = 41,
            
            // X = 2π * (ptr(data[1]) / ptr(data[2])) + ptr(data[3])
            // result = lerp(ptr(data[5]), ptr(data[4]), (sin(X)+1)*0.5) * ptr(data[0])
            Sinlerp2PtrMulPtr = 42,
            
            // rng() * data[2] + data[1] + data[0]
            RandLinearConst = 43,
            
            // Curve(ptr(data[0]), time) + ptr(data[1]) + ptr(data[3]) * data[2]
            CurveAddPtrAddPtrMulConst = 44,
            
            // ptr(data[0]) + ptr(data[1])
            PtrAddPtr = 45,
            
            // Curve(ptr(data[0]), time) + ptr(data[2]) * data[1]
            CurveAddPtrMulConst = 46, 
            
            // ptr(data[1]) + data[0] + ptr(data[3]) * data[2]
            PtrAddConstAddPtrMulConst = 47,
            
            // abs(lerp(Curve(data[2], time), Curve(data[1], time), ptr(data[0])) + ptr(data[3]))
            CurveCrossfadeAddAbs = 48,
            
            // abs(ptr(data[1]) * data[0])
            PtrMulConstAbsSafe = 49,
            
            // abs(lerp(Curve(data[2], time), Curve(data[1], time), ptr(data[0])) * ptr(data[3]))
            CurveCrossfadeMulAbs = 50,
            
            // Curve(ptr(data[0]), time) * ptr(data[1])
            CurveMulPtr = 51,
        } InstructionType;
        
        if (EnumToString(InstructionType) == "")
            Printf("Unsupported instruction %d", InstructionType);
    }
} VFX_VM;
        
